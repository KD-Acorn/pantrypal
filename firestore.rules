rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /pantry/{uid}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /saved_recipes/{uid}/recipes/{recipeId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /cook_history/{uid}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /substitutions/{uid}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /public_recipes/{recipeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
