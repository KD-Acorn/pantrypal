rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.uid == 'gTCwD1bHALeeNZ7wDNbt9sSEL8x1';
    }
    
    match /{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /pantry/{uid}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /saved_recipes/{uid}/recipes/{recipeId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /cook_history/{uid}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /substitutions/{uid}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /public_recipes/{recipeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /grocery/{uid}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /meal_plan/{uid}/days/{date} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /analytics_events/{docId} {
      allow write: if request.auth != null;
    }
    match /analytics_daily/{docId} {
      allow write: if request.auth != null;
    }
    match /bug_reports/{reportId} {
      allow write: if request.auth != null;
    }
    match /households/{householdId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    match /household_pantry/{householdId}/items/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /household_recipes/{householdId}/recipes/{recipeId} {
      allow read, write: if request.auth != null;
    }
    match /household_meal_plan/{householdId}/days/{date} {
      allow read, write: if request.auth != null;
    }
    match /household_activity/{householdId}/events/{eventId} {
      allow read, write: if request.auth != null;
    }
    match /household_invites/{email} {
      allow read, write: if request.auth != null;
    }
    match /pending_deletions/{docId} {
      allow read, write: if request.auth != null && 
        request.auth.uid == docId;
    }
  }
}